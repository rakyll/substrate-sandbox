# Substrate resources for the sandbox service: a namespace, a pool of
# pre-warmed workers, and the ActorTemplate every sandbox is created from.
#
# ${BUCKET_NAME} must be substituted with the object-storage bucket that
# holds suspend snapshots, e.g.:
#   BUCKET_NAME=my-bucket envsubst < manifests/sandbox.yaml.tmpl | ko apply -f -
apiVersion: v1
kind: Namespace
metadata:
  name: substrate-sandbox
---
apiVersion: ate.dev/v1alpha1
kind: WorkerPool
metadata:
  name: sandbox-workerpool
  namespace: substrate-sandbox
  labels:
    workload: sandbox
spec:
  replicas: 2
  ateomImage: ko://github.com/agent-substrate/substrate/cmd/ateom-gvisor
---
apiVersion: ate.dev/v1alpha1
kind: ActorTemplate
metadata:
  name: sandbox
  namespace: substrate-sandbox
spec:
  workerSelector:
    matchLabels:
      workload: sandbox
  pauseImage: "registry.k8s.io/pause:3.10.2@sha256:f548e0e8e3dc1896ca956272154dde3314e8cc4fde0a57577ee9fa1c63f5baf4"
  containers:
  - name: guestd
    image: ko://github.com/rakyll/substrate-sandbox/cmd/substrate-guestd
    command: ["/ko-app/substrate-guestd", "-workdir", "/workspace"]
    env:
    - name: PORT
      value: "80"
    readyz:
      httpGet:
        path: /healthz
        port: 80
  snapshotsConfig:
    location: gs://${BUCKET_NAME}/substrate-sandbox/
